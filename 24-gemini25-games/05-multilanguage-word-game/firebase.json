{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [ {
      "source" : "**/*.json",
      "headers" : [ {
        "key" : "Content-Type",
        "value" : "application/json"
      }  ,
      {
        "key": "Access-Control-Allow-Origin",
        "value": "*"
      }
    ]
    } ]

  }

}
